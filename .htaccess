# Enable Rewrite Engine
RewriteEngine On

# Redirect legacy English-prefixed URLs to the canonical root URLs
RewriteRule ^en/?$ / [R=301,L,NC]
RewriteRule ^en/(.*)$ /$1 [R=301,L,NC]

# Handle language routes - redirect to index.html with language code
# Example: /fa -> /index.html (client-side will handle the language)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Check if the first segment is a supported non-default language code
RewriteCond %{REQUEST_URI} ^/(fa|zh|ru|it|ar|nl)(/.*)?$ [NC]
RewriteRule ^(fa|zh|ru|it|ar|nl)(/.*)?$ /index.html [L]

# Fallback: serve index.html for all other routes (for SPA behavior)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Set cache headers for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(?:avif|gif|ico|jpe?g|png|svg|webp|woff2)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    <FilesMatch "^.*_next/static/.*$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>
